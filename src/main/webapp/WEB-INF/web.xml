<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- 🔥 欢迎页配置：访问 /JavaWeb 直接打开 index.jsp（已正确，保留） -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- 1. LifeCycleServlet：包名 com.huangjunjie.week3.demo（目录匹配） -->
    <servlet>
        <servlet-name>LifeCycleServlet</servlet-name>
        <servlet-class>com.huangjunjie.week3.demo.LifeCycleServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>LifeCycleServlet</servlet-name>
        <url-pattern>/lifeCycle</url-pattern>
    </servlet-mapping>

    <!-- 2. RegisterServlet：包名 com.huangjunjie.week3.demo（目录匹配） -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.huangjunjie.week3.demo.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/registerServlet</url-pattern>
    </servlet-mapping>

    <!-- 3. SearchServlet：包名 com.huangjunjie.week3.demo（目录匹配） -->
    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>com.huangjunjie.week3.demo.SearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>

    <!-- 4. LoginServlet：包名 com.huangjunjie.week5.demo（目录匹配，已正确，保留） -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.huangjunjie.week5.demo.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

</web-app>